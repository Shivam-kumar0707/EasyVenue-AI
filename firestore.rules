rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Permissive rules for stadium zones and their historical trend subcollections
    match /zones/{zoneId} {
      allow read, write: if true;
      
      match /history/{docId} {
        allow read, write: if true;
      }
    }
    
    // Permissive rules for incident reports
    match /incidents/{incidentId} {
      allow read, write: if true;
    }
    
    // Permissive rules for organizer PA announcements
    match /announcements/{announcementId} {
      allow read, write: if true;
    }
    
  }
}
