rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // NOTE: These rules are intentionally permissive to allow public reads and writes for
    // a public hackathon/demo dashboard vertical (no authentication flow implemented).
    // However, they strictly validate incoming document schemas to prevent database-bypass
    // script injections or data overflow.
    // In production, these rules must be locked down to authenticated organizer/staff roles.

    match /zones/{zoneId} {
      allow read: if true;
      allow write: if true;
      
      match /history/{docId} {
        allow read: if true;
        // Validate simulation ticks values
        allow write: if request.resource.data.crowdLevel is number
                     && request.resource.data.crowdLevel >= 0
                     && request.resource.data.crowdLevel <= 100;
      }
    }
    
    match /incidents/{incidentId} {
      allow read: if true;
      // Enforce incident categories, severities, and text size constraints
      allow write: if request.resource.data.category in ['Crowd Size', 'Medical', 'Safety', 'Infrastructure', 'Other']
                   && request.resource.data.severity in ['Low', 'Medium', 'High']
                   && request.resource.data.description is string
                   && request.resource.data.description.size() <= 500;
    }
    
    match /announcements/{announcementId} {
      allow read: if true;
      // Enforce situation input size and text properties
      allow write: if request.resource.data.situationInput is string
                   && request.resource.data.situationInput.size() <= 300
                   && request.resource.data.text is string;
    }
    
  }
}
