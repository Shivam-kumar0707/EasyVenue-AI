rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // NOTE: These rules are intentionally permissive to allow public reads and writes for
    // a public hackathon/demo dashboard vertical (no authentication flow implemented).
    // However, they strictly validate incoming document schemas to prevent database-bypass
    // script injections or data overflow.
    // In production, these rules must be locked down to authenticated organizer/staff roles.

    match /zones/{zoneId} {
      allow read: if true;
      allow write: if true;
      
      match /history/{docId} {
        allow read: if true;
        // Validate simulation ticks values
        allow create, update: if request.resource.data.crowdLevel is number
                              && request.resource.data.crowdLevel >= 0
                              && request.resource.data.crowdLevel <= 100;
        allow delete: if true;
      }
    }
    
    match /incidents/{incidentId} {
      allow read: if true;
      // Enforce incident categories, severities, status, and rawText size constraints
      allow create, update: if request.resource.data.category in ['crowd_control', 'medical', 'security', 'facility', 'lost_person', 'unclassified']
                           && request.resource.data.severity in ['low', 'medium', 'high']
                           && request.resource.data.rawText is string
                           && request.resource.data.rawText.size() <= 500
                           && request.resource.data.status in ['open', 'acknowledged', 'resolved'];
      allow delete: if true;
    }
    
    match /announcements/{announcementId} {
      allow read: if true;
      // Enforce situation input size and text properties
      allow create, update: if request.resource.data.situationInput is string
                           && request.resource.data.situationInput.size() <= 300
                           && request.resource.data.text is string;
      allow delete: if true;
    }
    
  }
}
