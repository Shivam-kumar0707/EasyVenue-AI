rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // NOTE: These rules are intentionally permissive to allow public reads and writes for
    // a public hackathon/demo dashboard vertical (no authentication flow implemented).
    // They validate incoming document schemas on user-submitted collections (incidents, announcements)
    // to prevent database-bypass script injections or data overflow.
    // In production, these rules must be locked down to authenticated organizer/staff roles.

    match /zones/{zoneId} {
      allow read, write: if true;
      
      match /history/{docId} {
        allow read, write: if true;
      }
    }
    
    match /incidents/{incidentId} {
      allow read: if true;
      // Enforce category, severity, status enums, and size limits (supporting both old seeded data and new AI categories)
      allow create, update: if request.resource.data.category in ['crowd_control', 'medical', 'security', 'facility', 'lost_person', 'unclassified', 'Crowd Size', 'Medical', 'Safety', 'Infrastructure', 'Other']
                           && request.resource.data.severity in ['low', 'medium', 'high', 'Low', 'Medium', 'High']
                           && request.resource.data.status in ['open', 'acknowledged', 'resolved', 'Open', 'Acknowledged', 'Resolved']
                           && request.resource.data.zone in ['Gate 1', 'Gate 2', 'Gate 3', 'Food Court', 'Main Concourse']
                           && (!('rawText' in request.resource.data) || (request.resource.data.rawText is string && request.resource.data.rawText.size() <= 500))
                           && (!('description' in request.resource.data) || (request.resource.data.description is string && request.resource.data.description.size() <= 500));
      allow delete: if true;
    }
    
    match /announcements/{announcementId} {
      allow read: if true;
      // Enforce situation input size and text properties
      allow create, update: if (!('situationInput' in request.resource.data) || (request.resource.data.situationInput is string && request.resource.data.situationInput.size() <= 300))
                           && (!('text' in request.resource.data) || request.resource.data.text is string);
      allow delete: if true;
    }
    
  }
}
